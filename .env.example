# ==========================================
# LoveStory Environment Variables
# Copy this file to .env and modify as needed
# ==========================================

# Node backend API & Production serving port
PORT=3001

# Vite frontend dev server port
VITE_PORT=3000

# Main access passcode (Default: 1111)
VITE_MAIN_PASSCODE=1111

# Passcode required to add/edit/delete memories (Default: 2222)
VITE_ADD_PASSCODE=2222

# How long a passcode remains valid in milliseconds (Default: 86400000 = 24 hours)
VITE_UNLOCK_EXPIRY_MS=86400000

# =========================================================================
# ====== [可选] 云对象存储配置 (配置后将不再占用本地磁盘，直接直传) ======
# =========================================================================

# --- 方案 A: Cloudflare R2 / 兼容 S3 的私密存储 (极度推荐，免费且保护隐私) ---
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# S3_BUCKET_NAME=lovestory-media
# S3_PUBLIC_DOMAIN=https://pub-xxxxx.r2.dev

# --- 方案 B: Imgur 免费图床 (警告：上传的图片会公开于外网，无任何隐私保护) ---
# IMGUR_CLIENT_ID=your_client_id
